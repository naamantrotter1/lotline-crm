{
  "version": 2,
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "crons": [
    {
      "path": "/api/sync-gmail-replies",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/sc-data-staleness",
      "schedule": "0 13 * * *"
    }
  ],
  "routes": [
    {
      "src": "/homes/(.*)",
      "headers": { "Cache-Control": "no-cache, must-revalidate" },
      "continue": true
    },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
