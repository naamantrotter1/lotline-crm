# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lotline_intelligence
DB_USER=lotline
DB_PASSWORD=lotline_secret

# ─── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Free Public Data API Keys ───────────────────────────────────────────────
# Get a free Census API key at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=your_census_api_key_here

# BLS public API key (optional, increases rate limits)
# Register at: https://data.bls.gov/registrationEngine/
BLS_API_KEY=your_bls_api_key_here

# ─── FUTURE PAID DATA SOURCES (placeholder — plug in keys when purchased) ────
# Trestle MLS (CoreLogic) — contact: https://trestle.corelogic.com
TRESTLE_CLIENT_ID=
TRESTLE_CLIENT_SECRET=
TRESTLE_BASE_URL=https://api.listhub.com/reso/odata

# ATTOM Property Data — https://api.attomdata.com
ATTOM_API_KEY=

# Mapbox (optional if switching from Leaflet to Mapbox GL JS)
# VITE_MAPBOX_TOKEN=pk.your_mapbox_token_here

# ─── Frontend ────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001
